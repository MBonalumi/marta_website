---
const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-charcoal text-white py-16">
  <div class="container mx-auto px-6">
    <div class="grid md:grid-cols-3 gap-12 border-b border-white/10 pb-12 mb-12">
      
      <div>
        <h3 class="text-2xl font-serif font-bold mb-6 text-brand-sage">Marta Degani</h3>
        <p class="text-white/60 leading-relaxed">
          Psicologa iscritta all'Ordine degli Psicologi della Lombardia. Supporto psicologico e percorsi di benessere.
        </p>
      </div>

      <div>
        <h4 class="font-bold mb-6 uppercase tracking-wider text-sm">Collegamenti</h4>
        <nav class="flex flex-col space-y-4 text-white/60">
          <a href="#home" class="hover:text-brand-sage transition-colors">Home</a>
          <a href="#chi-sono" class="hover:text-brand-sage transition-colors">Chi Sono</a>
          <a href="#servizi" class="hover:text-brand-sage transition-colors">Servizi</a>
          <a href="#contatti" class="hover:text-brand-sage transition-colors">Contatti</a>
        </nav>
      </div>

      <div>
        <h4 class="font-bold mb-6 uppercase tracking-wider text-sm">Contatti Rapidi</h4>
        <p class="text-white/60 mb-2">martadegani.md@gmail.com</p>
        <p class="text-white/60">Como | Pasturo | Online</p>
      </div>

    </div>

    <div class="flex flex-col md:flex-row justify-between items-center text-sm text-white/40">
      <p>&copy; {currentYear} Marta Degani. Tutti i diritti riservati.</p>
      <div class="flex gap-6 mt-4 md:mt-0">
        <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-white transition-colors">Cookie Policy</a>
      </div>
    </div>
  </div>
</footer>
