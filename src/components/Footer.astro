---
const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-charcoal text-white py-16">
  <div class="container mx-auto px-6">
    <div
      class="grid md:grid-cols-3 gap-12 border-b border-white/10 pb-12 mb-12"
    >
      <div>
        <h3 class="text-2xl font-serif font-bold mb-6 text-brand-sage">
          Marta Degani
        </h3>
        <p class="text-white/60 leading-relaxed">
          Psicologa iscritta all'Ordine degli Psicologi della Lombardia.
          Supporto psicologico e percorsi di benessere.
        </p>
      </div>

      <div>
        <h4 class="font-bold mb-6 uppercase tracking-wider text-sm">
          Collegamenti
        </h4>
        <nav class="flex flex-col space-y-4 text-white/60">
          <a href="#home" class="hover:text-brand-sage transition-colors"
            >Home</a
          >
          <a href="#chi-sono" class="hover:text-brand-sage transition-colors"
            >Chi Sono</a
          >
          <a href="#servizi" class="hover:text-brand-sage transition-colors"
            >Servizi</a
          >
          <a href="#contatti" class="hover:text-brand-sage transition-colors"
            >Contatti</a
          >
        </nav>
      </div>

      <div>
        <h4 class="font-bold mb-6 uppercase tracking-wider text-sm">
          Contatti Rapidi
        </h4>
        <p class="text-white/60 mb-2">martadegani.md@gmail.com</p>
        <p class="text-white/60">Como | Pasturo | Online</p>

        <div class="flex gap-4 mt-6">
          <a
            href="https://www.instagram.com/martadegani_psicologa/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-white/60 hover:text-brand-sage transition-colors"
            aria-label="Instagram"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linejoin="round"
            >
              <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/in/marta-degani-psicologiadelbenessere/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-white/60 hover:text-brand-sage transition-colors"
            aria-label="LinkedIn"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
              ></path>
              <rect width="4" height="12" x="2" y="9"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div
      class="flex flex-col md:flex-row justify-between items-center text-sm text-white/40"
    >
      <p>&copy; {currentYear} Marta Degani. Tutti i diritti riservati.</p>
      <div class="flex gap-6 mt-4 md:mt-0">
        <a href="#" class="hover:text-white transition-colors">Privacy Policy</a
        >
        <a href="#" class="hover:text-white transition-colors">Cookie Policy</a>
      </div>
    </div>
  </div>
</footer>
